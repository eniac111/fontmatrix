{
    "id": "com.github.fontmatrix.Fontmatrix",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "base": "io.qt.qtwebengine.BaseApp",
    "base-version": "6.10",
    "sdk": "org.kde.Sdk",
    "rename-icon": "fontmatrix",
    "rename-desktop-file": "fontmatrix.desktop",
    "command": "fontmatrix",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=/usr/share/fonts:ro",
        "--filesystem=/usr/local/share/fonts:ro",
        "--filesystem=xdg-data/fonts",
        "--filesystem=home/.fonts:ro",
        "--filesystem=xdg-config/fontconfig",
        "--filesystem=/tmp"
    ],
    "cleanup": [
        "/share/man"
    ],
    "cleanup-commands": [
        "/app/cleanup-BaseApp.sh"
    ],
    "modules": [
        {
            "name": "fontmatrix",
            "buildsystem": "cmake-ninja",
            "post-install": [
                "install -Dm644 -T src/icons/application-fontmatrix_64.png /app/share/icons/hicolor/64x64/apps/fontmatrix.png",
                "install -Dm644 -T src/icons/application-fontmatrix_128.png /app/share/icons/hicolor/128x128/apps/fontmatrix.png",
                "install -Dm644 -T src/icons/application-fontmatrix-vectors.svg /app/share/icons/hicolor/scalable/apps/fontmatrix.svg"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
